+    "MatrixFreeSolverProtocol",
+    "PreconditionerProtocol",
+    "PreconditionerWithSetupProtocol",
+    # Boundary conditions
+    "BoundaryConditionProtocol",
+    "BoundaryConditionWithParamJacobianProtocol",
+    "DirichletBCProtocol",
+    "RobinBCProtocol",
+]
