+        # Initial condition at final time
         deltat_N = float(times[-1] - times[-2])
         self._time_residual.set_time(
             float(times[-2]), deltat_N, fwd_sols[:, -2]
         )
 
-        # d²Q/dy² · w_N - d²Q/dydp · v
+        # Functional Hessian terms at final time
