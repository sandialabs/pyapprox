+        x_test = torch.tensor([[0.5]], requires_grad=True)
+        jac = gp.jacobian(x_test)
+
+        # Finite difference
+        eps = 1e-6
+        x_plus = torch.tensor([[0.5 + eps]])
+        x_minus = torch.tensor([[0.5 - eps]])
