@@ -406,25 +423,44 @@ class TimeAdjointOperatorWithHVP(Generic[Array]):
         s_sols = self._bkd.zeros(fwd_sols.shape)
         s_sols = self._bkd.copy(s_sols)
 
-        # Initial condition at final time: similar to first adjoint
