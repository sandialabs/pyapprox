+        dQdy_final = 1.0  # dQ/dy = 1 for endpoint functional Q = y(T)
+        adj_sols_ana = sympy_adjoint_backward_euler(fwd_sols_ana, deltat, p, a, dQdy_final)
+
+        # Compare
+        for n in range(len(times)):
+            error = abs(float(adj_sols_num[0, n]) - adj_sols_ana[n])
