+        # Check if explicit scheme (Forward Euler, Heun)
+        class_name = self._time_residual.__class__.__name__
+        self._explicit_scheme = "ForwardEuler" in class_name or "Heun" in class_name
+
+    def _is_explicit_scheme(self) -> bool:
