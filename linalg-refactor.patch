+        # CORRECTED RHS: -∇_{yy}L·w - ∇_{yu}L·v
+        # (negative sign on Lyy·w because our w = -w_Heinkenschloss)
+        rhs_N = -(qss_hvp.flatten() + rss_hvp) - (qsp_hvp.flatten() + rsp_hvp)
