         qss_hvp = self._functional.state_state_hvp(
             fwd_sols, param, ntimes - 1, w_sols[:, -1:]
         )
         qsp_hvp = self._functional.state_param_hvp(
             fwd_sols, param, ntimes - 1, vvec
