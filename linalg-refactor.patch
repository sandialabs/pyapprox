+
+        For Forward Euler: d²R/dpdy = -Δt·(d²f/dpdy)
+        """
+        self._residual.set_time(self._time)
+        return -self._deltat * self._residual.param_state_hvp(
+            fsol_nm1, adj_state, wvec
+        )
+
+    def _param_param_hvp(
